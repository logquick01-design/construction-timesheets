{
  "name": "logq",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run prisma:sync && next dev -H 127.0.0.1 -p 3000",
    "build": "npm run prisma:sync && next build",
    "start": "bash scripts/start-production.sh",
    "start:production": "bash scripts/start-production.sh",
    "lint": "next lint",
    "prisma:sync": "prisma generate && node scripts/write-prisma-fingerprint.mjs",
    "db:push": "prisma db push && npm run prisma:sync",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:push && tsx prisma/seed.ts",
    "postinstall": "npm run prisma:sync"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "jose": "^6.0.11",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.513.0",
    "next": "^15.3.3",
    "prisma": "^6.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.3.0",
    "tsx": "^4.19.4",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
