generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SITE_MANAGER
  QS
}

enum LabourRequestStatus {
  PENDING
  ACCEPTED
  DENIED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  siteAssignments              SiteManagerAssignment[]
  siteDashboardPreferences     UserSiteDashboardPreference[]
  labourRequestsRequested      LabourRequest[] @relation("LabourRequestedBy")
  labourRequestsReviewed       LabourRequest[] @relation("LabourReviewedBy")
}

model Site {
  id        String   @id @default(cuid())
  name      String
  location  String
  active    Boolean  @default(true)
  taskBudgetWidget Json @default("[]")
  features  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managers              SiteManagerAssignment[]
  dashboardPreferences  UserSiteDashboardPreference[]
  companies             Company[]
  workers    Worker[]
  categories CostCodeCategory[]
  tasks      CostCodeTask[]
  timesheets TimesheetEntry[]
  labourRequests LabourRequest[]
  notifications  SiteNotification[]
}

model SiteManagerAssignment {
  id     String @id @default(cuid())
  userId String
  siteId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([userId, siteId])
}

model UserSiteDashboardPreference {
  id        String   @id @default(cuid())
  userId    String
  siteId    String
  widgets     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([userId, siteId])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  siteId    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site    Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  workers Worker[]

  @@unique([siteId, name])
  @@index([siteId])
}

model Person {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workers Worker[]
}

model Worker {
  id        String   @id @default(cuid())
  name      String
  trade     String
  siteId    String
  companyId String?
  personId  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site       Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  company    Company?         @relation(fields: [companyId], references: [id])
  person     Person?          @relation(fields: [personId], references: [id])
  timesheets TimesheetEntry[]
  labourRequestWorkers LabourRequestWorker[]

  @@index([siteId])
  @@index([companyId])
  @@index([personId])
}

model CostCodeCategory {
  id        String   @id @default(cuid())
  name      String
  siteId    String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site  Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  tasks CostCodeTask[]

  @@unique([siteId, name])
  @@index([siteId])
}

model CostCodeTask {
  id         String   @id @default(cuid())
  name       String
  reference  String
  siteId     String
  categoryId String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  site       Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category   CostCodeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  timesheets TimesheetEntry[]

  @@index([siteId])
  @@index([categoryId])
}

model TimesheetEntry {
  id        String   @id @default(cuid())
  workerId  String
  siteId    String
  taskId    String
  date      DateTime
  hours     Float
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worker Worker       @relation(fields: [workerId], references: [id])
  site   Site         @relation(fields: [siteId], references: [id])
  task   CostCodeTask @relation(fields: [taskId], references: [id])

  @@index([siteId, date])
  @@index([workerId, date])
}

model LabourRequest {
  id            String              @id @default(cuid())
  siteId        String
  status        LabourRequestStatus @default(PENDING)
  notes         String?
  requestedById String
  reviewedById  String?
  reviewedAt    DateTime?
  denialReason  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  site        Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  requestedBy User                  @relation("LabourRequestedBy", fields: [requestedById], references: [id])
  reviewedBy  User?                 @relation("LabourReviewedBy", fields: [reviewedById], references: [id])
  days        LabourRequestDay[]
  workers     LabourRequestWorker[]

  @@index([siteId, status])
  @@index([status])
}

model LabourRequestDay {
  id              String   @id @default(cuid())
  labourRequestId String
  date            DateTime

  labourRequest LabourRequest @relation(fields: [labourRequestId], references: [id], onDelete: Cascade)

  @@unique([labourRequestId, date])
  @@index([date])
}

model LabourRequestWorker {
  id              String @id @default(cuid())
  labourRequestId String
  workerId        String
  hoursPerDay     Float  @default(8)

  labourRequest LabourRequest @relation(fields: [labourRequestId], references: [id], onDelete: Cascade)
  worker         Worker       @relation(fields: [workerId], references: [id])

  @@unique([labourRequestId, workerId])
}

model SiteNotification {
  id        String   @id @default(cuid())
  siteId    String
  type      String
  title     String
  message   String
  meta      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, read])
}
